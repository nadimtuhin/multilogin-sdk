{
  "name": "multilogin-x-sdk",
  "version": "1.1.2",
  "description": "TypeScript SDK for Multilogin X API - generated from Postman collection",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup src/index.ts --outDir dist --format esm",
    "build:types": "tsup src/index.ts --outDir dist --format esm --dts"
  },
  "keywords": [
    "multilogin",
    "sdk",
    "api",
    "typescript",
    "browser-profiles",
    "automation"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@sirhc77/postman-sdk-gen": "^0.2.0",
    "@types/node": "^25.3.3",
    "tsup": "^8.5.1",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
}
