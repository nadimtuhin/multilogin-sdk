# Multilogin X SDK Configuration
# Copy to .env and fill in your credentials

# Your Multilogin credentials (for login script)
MULTILOGIN_EMAIL=your-email@example.com
MULTILOGIN_PASSWORD=your-password

# API base URL (optional, defaults to https://api.multilogin.com)
MULTILOGIN_BASE_URL=https://api.multilogin.com

# Your JWT token (generated via login.mjs or from dashboard)
# MULTILOGIN_TOKEN=your-jwt-token-here
